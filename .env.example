# Shared local/production environment for the whole NextPath monorepo.
# Copy this file to `.env` and edit real secrets locally/on the host.
# Never commit `.env`.

# Backend / PostgreSQL
DATABASE_URL=postgresql://nextpath_app:REAL_PASSWORD@127.0.0.1:5432/nextpath
CREATE_TABLES_ON_STARTUP=true
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGINS=https://nextpath.su,https://www.nextpath.su,http://localhost:5173,http://localhost:3000

# Frontend build-time variables can live here too when needed.
# VITE_API_BASE_URL=/api
