# Shared local/production environment for the whole NextPath monorepo.
# Copy this file to `.env` and edit real secrets locally/on the host.
# Never commit `.env`.

# Backend / PostgreSQL
DATABASE_URL=postgresql://nextpath_app:REAL_PASSWORD@127.0.0.1:5432/nextpath
CREATE_TABLES_ON_STARTUP=true
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGINS=https://nextpath.su,https://www.nextpath.su,https://my.nextpath.su,http://localhost:5173,http://localhost:3000

# URLs для cross-domain редиректов (Vite — только с префиксом VITE_)
VITE_CABINET_URL=https://my.nextpath.su
VITE_MAIN_URL=https://nextpath.su

# Groq API — генерация персонального роудмапа
# Бесплатный ключ: https://console.groq.com
GROQ_API_KEY=

# Google OAuth — авторизация пользователей
# Создать в console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
JWT_SECRET=замени-на-случайную-строку

# Vite: открытые переменные для браузера (нужен префикс VITE_)
VITE_GOOGLE_CLIENT_ID=
